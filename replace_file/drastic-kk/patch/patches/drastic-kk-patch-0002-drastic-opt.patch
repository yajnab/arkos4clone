+static int mark_double_spaces(char *p)
+{
+    int cc = 0;
+    int len = strlen(p);
+
+    for (cc=0; cc<len - 1; cc++) {
+        if ((p[cc] == ' ') && (p[cc + 1] == ' ')) {
+            p[cc] = 0;
+            return 0;
+        }
+    }
+    return -1;
+}
+
+static char* find_menu_string_tail(char *p)
+{
+    int cc = 0;
+
+    for (cc=strlen(p) - 1; cc>=0; cc--) {
+        if (p[cc] == ' ') {
+            return &p[cc + 1];
+        }
+    }
+    return NULL;
+}
