+int nds_settings_load_alpha(void)
+{
+    json_object *jfile, *jval;
+    int alpha = -1;
+
+    if (g_settings_path[0] == '\0')
+        return -1;
+
+    jfile = json_object_from_file(g_settings_path);
+    if (!jfile)
