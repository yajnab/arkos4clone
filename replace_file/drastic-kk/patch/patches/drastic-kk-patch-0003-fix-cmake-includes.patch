From 115764776d45478678d08428e81bd43ac5d7e37d Mon Sep 17 00:00:00 2001
From: lcdyk <lcdyk0517@qq.com>
Date: Thu, 26 Feb 2026 14:51:52 +0800
Subject: [PATCH 3/6] Fix: Add CMake configuration and reorder includes for
 drastic-specific features

- Add pkg_check_modules for json-c, SDL2_image, and SDL2_ttf
- Add include directories for these dependencies to SDL2 and SDL2-static targets
- Reorder includes in SDL_render.c to prevent SDL header conflicts
  Move SDL2_ttf and SDL_image includes after project headers
---
 CMakeLists.txt          | 25 +++++++++++++++++++++++++
 src/render/SDL_render.c |  4 +++-
 2 files changed, 28 insertions(+), 1 deletion(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index de2766362..50a96db92 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -73,6 +73,11 @@ include(GNUInstallDirs)
 
 find_package(PkgConfig)
 
+# Find dependencies for drastic-specific features
+pkg_check_modules(JSONC json-c)
+pkg_check_modules(SDL2_IMAGE SDL2_image)
+pkg_check_modules(SDL2_TTF SDL2_ttf)
+
 list(APPEND CMAKE_MODULE_PATH "${SDL2_SOURCE_DIR}/cmake")
 include(${SDL2_SOURCE_DIR}/cmake/macros.cmake)
 include(${SDL2_SOURCE_DIR}/cmake/sdlchecks.cmake)
@@ -3501,6 +3506,16 @@ if(SDL_SHARED)
       "$<INSTALL_INTERFACE:${CMAKE_INSTALL_INCLUDEDIR}>"
       "$<INSTALL_INTERFACE:${CMAKE_INSTALL_INCLUDEDIR}/SDL2>"
   )
+  # Add include directories for drastic-specific features
+  if(JSONC_FOUND)
+    target_include_directories(SDL2 PRIVATE ${JSONC_INCLUDE_DIRS})
+  endif()
+  if(SDL2_IMAGE_FOUND)
+    target_include_directories(SDL2 PRIVATE ${SDL2_IMAGE_INCLUDE_DIRS})
+  endif()
+  if(SDL2_TTF_FOUND)
+    target_include_directories(SDL2 PRIVATE ${SDL2_TTF_INCLUDE_DIRS})
+  endif()
   # This picks up all the compiler options and such we've accumulated up to here.
   target_link_libraries(SDL2 PRIVATE $<BUILD_INTERFACE:sdl-build-options>)
   if(MINGW OR CYGWIN)
@@ -3537,6 +3552,16 @@ if(SDL_STATIC)
       "$<INSTALL_INTERFACE:${CMAKE_INSTALL_INCLUDEDIR}>"
       "$<INSTALL_INTERFACE:${CMAKE_INSTALL_INCLUDEDIR}/SDL2>"
   )
+  # Add include directories for drastic-specific features
+  if(JSONC_FOUND)
+    target_include_directories(SDL2-static PRIVATE ${JSONC_INCLUDE_DIRS})
+  endif()
+  if(SDL2_IMAGE_FOUND)
+    target_include_directories(SDL2-static PRIVATE ${SDL2_IMAGE_INCLUDE_DIRS})
+  endif()
+  if(SDL2_TTF_FOUND)
+    target_include_directories(SDL2-static PRIVATE ${SDL2_TTF_INCLUDE_DIRS})
+  endif()
   # This picks up all the compiler options and such we've accumulated up to here.
   target_link_libraries(SDL2-static PRIVATE $<BUILD_INTERFACE:sdl-build-options>)
   if(NOT ANDROID)
diff --git a/src/render/SDL_render.c b/src/render/SDL_render.c
index 1a51028ff..127593f54 100644
--- a/src/render/SDL_render.c
+++ b/src/render/SDL_render.c
@@ -41,9 +41,11 @@
 #endif
 
 #include <sys/mman.h>
+#include "jsonlayout.h"
+
+/* Include SDL2_ttf and SDL2_image after project headers to avoid conflicts */
 #include <SDL2/SDL_ttf.h>
 #include <SDL2/SDL_image.h>
-#include "jsonlayout.h"
 
 /* as a courtesy to iOS apps, we don't try to draw when in the background, as
 that will crash the app. However, these apps _should_ have used
-- 
